LLM_PRIMARY=gemini
LLM_FALLBACK=bedrock

AWS_REGION=ca-central-1
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0
GEMINI_MODEL=gemini-2.5-flash


AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key


GEMINI_API_KEY=your_gemini_api_key


SYSTEM_PROMPT=You are a helpful assistant for our hackathon prototype. Be concise.


# --- Persistence (optional; in-memory fallback when unset, see docs/db-setup.md) ---
# DYNAMODB_TABLE_NAME=SecondLifePassport

# --- CORS (defaults to localhost:5173 + the Vercel app when unset) ---
# ALLOWED_ORIGINS=http://localhost:5173,https://amazon-hackon.vercel.app

# --- Stage safety / hardening ---
# FORCE_CACHED=1            # serve only cached AI responses — no live model calls (kill switch)
# ENABLE_CHAT=1            # re-enable the legacy /chat endpoint (404 by default)
# METRICS_RESET_TOKEN=     # required to call POST /metrics/reset?token=... (else 401)
